FROM python:3.12-slim

# Evita prompts interativos durante apt
ENV DEBIAN_FRONTEND=noninteractive

# Dependências de sistema necessárias para psycopg2 e pyarrow
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Instala dependências Python primeiro (camada cacheável)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copia os scripts
COPY extract.py .
COPY load.py .
COPY utils.py .

# Pasta de dados montada em runtime via volume no docker-compose
# Não copiar data/ aqui — será montada via volume
RUN mkdir -p /app/data

# Variáveis de ambiente com valores padrão (sobrescritas pelo .env)
ENV POSTGRES_HOST=postgres \
    POSTGRES_PORT=5432 \
    POSTGRES_DB=anac_dw \
    POSTGRES_USER=airflow \
    POSTGRES_PASSWORD=airflow \
    DATA_PATH=/app/data

# Ponto de entrada padrão: roda extract depois load em sequência
CMD ["sh", "-c", "python extract.py && python load.py"]
